# Copy this file to .env and fill in your values. Do NOT commit your real .env.

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Steam API Key - Required for data ingestion
# Get one from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# ============================================================================
# DATABASE & CACHE CONFIGURATION
# ============================================================================

# Database file path
DB_PATH=./data/dlns.sqlite3

# API Configuration
API_LATEST_LIMIT=50

# Cache Configuration
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=60
COMPRESS_LEVEL=6
COMPRESS_BR_LEVEL=5
COMPRESS_MIN_SIZE=256

# ============================================================================
# EXTERNAL LINKS (used in templates)
# ============================================================================

YOUTUBE_URL=https://www.youtube.com/@your_channel
TWITCH_URL=https://www.twitch.tv/your_channel
DEADLOCK_URL=https://store.steampowered.com/app/1422450/Deadlock/
KOFI_URL=https://ko-fi.com/your_username
PATREON_URL=https://www.patreon.com/your_patreon

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Base URL for the application
BASE_URL=http://localhost:5050

# Hero API version for fetching (only update if game changes heroes)
HERO_API_VERSION=5902

# Open Graph image (place in /static folder)
OG_IMAGE=og.png

# Community VO sheet CSV export URL (server-side fetch only)
VO_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=920587998

# ============================================================================
# DISCORD AUTHENTICATION & PERMISSIONS
# ============================================================================

# Discord OAuth Application credentials
# Create app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:5050/auth/discord/callback

# Discord IDs
DISCORD_OWNER_ID=your_discord_user_id
# Comma-separated Discord IDs for admin privileges (optional)
DISCORD_ADMIN_IDS=

# Discord IDs allowed to upload community mods
COMMUNITY_MOD_UPLOADER_IDS=111111111111111111,222222222222222222

# ============================================================================
# FLASK SESSION CONFIGURATION
# ============================================================================

# Generate a secure SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_secure_random_key_here
SESSION_COOKIE_NAME=dlns_stats_session
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax