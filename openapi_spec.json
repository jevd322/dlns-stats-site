    "/db/matches/latest/paged": {
      "get": {
        "tags": ["Matches"],
        "summary": "Get paginated latest matches",
        "parameters": [
          {"name": "page", "in": "query", "required": false, "description": "Page number.", "schema": {"type": "integer", "default": 1, "minimum": 1}},
          {"name": "per_page", "in": "query", "required": false, "description": "Items per page, max 20.", "schema": {"type": "integer", "default": 20, "minimum": 1, "maximum": 20}},
          {"name": "order", "in": "query", "required": false, "description": "Sort order.", "schema": {"type": "string", "enum": ["asc", "desc"], "default": "desc"}},
          {"name": "team", "in": "query", "required": false, "description": "Winning team filter.", "schema": {"type": "string", "enum": ["0", "1"]}},
          {"name": "game_mode", "in": "query", "required": false, "description": "Exact game mode filter.", "schema": {"type": "string"}},
          {"name": "match_mode", "in": "query", "required": false, "description": "Exact match mode filter.", "schema": {"type": "string"}},
          {"name": "hero", "in": "query", "required": false, "description": "Case-insensitive hero name substring.", "schema": {"type": "string"}},
          {"name": "player", "in": "query", "required": false, "description": "Persona name substring.", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Paginated recent matches",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {"$ref": "#/components/schemas/Pagination"},
                    {"type": "object", "properties": {"matches": {"type": "array", "items": {"$ref": "#/components/schemas/MatchWithPlayers"}}}}
                  ]
                }
              }
            }
          }
        }
      }
    },
