  "paths": {
    "/db/weeks": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get week and event mappings",
        "description": "Returns match-to-week mapping and event details derived from matches.json.",
        "responses": {
          "200": {
            "description": "Week mapping response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "weeks": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "integer",
                        "nullable": true
                      }
                    },
                    "details": {
                      "type": "object",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/WeekDetail"
                      }
                    },
                    "title": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/db/stats/overview": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get aggregate match overview",
        "parameters": [
          {
            "name": "event_title",
            "in": "query",
            "required": false,
            "description": "Optional event title filter.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Overview stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "overview": {
                      "$ref": "#/components/schemas/OverviewStats"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/db/stats/weekly": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get weekly event stats",
        "parameters": [
          {
            "name": "event_title",
            "in": "query",
            "required": false,
            "description": "Event title filter. Defaults to Night Shift.",
            "schema": {
              "type": "string",
              "default": "Night Shift"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Weekly aggregated stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "weeks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WeeklyStats"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/db/stats/records": {
      "get": {
