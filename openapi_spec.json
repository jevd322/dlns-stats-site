{
  "openapi": "3.0.3",
  "info": {
    "title": "DLNS Stats API",
    "version": "2026.04",
    "description": "Current OpenAPI description for the DLNS Stats site. The primary JSON API lives under /db, with additional community endpoints under /api/community and /community.json.",
    "contact": {
      "name": "DLNS Stats",
      "url": "https://dlns-stats.co.uk"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "https://dlns-stats.co.uk",
      "description": "Production server"
    },
    {
      "url": "http://localhost:5050",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "Stats",
      "description": "Aggregated and event-level statistics."
    },
    {
      "name": "Matches",
      "description": "Recent matches and per-match detail."
    },
    {
      "name": "Users",
      "description": "User profiles, aggregates, and match history."
    },
    {
      "name": "Search",
      "description": "Typeahead search suggestions."
    },
    {
      "name": "Heroes",
      "description": "Hero dictionaries and hero-specific stats."
    },
    {
      "name": "Community",
      "description": "Community link and metadata endpoints."
    }
  ],
